# Bundle artifacts
.vendor/
vendor/
.bundle/
.jekyll_cache

_site/

# Include the vendored Tone.js file
!js/vendor/

# npm (used only for Capacitor)
node_modules/

# Regenerated by `npx cap sync android` — never commit.
# (android/.gitignore from the Capacitor template covers the rest.)
android/app/capacitor.build.gradle
android/local.properties

# The Gradle wrapper must be committed for CI builds; override the
# global gitignore, which excludes gradlew everywhere.
!android/gradlew
!android/gradlew.bat

